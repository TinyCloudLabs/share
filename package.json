{
  "name": "share",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.viewer.config.ts",
    "test:e2e:email": "node test/e2e-email/integration.mjs",
    "typecheck": "tsc --noEmit",
    "sync:wireframes": "cp wireframes/*.svg public/wireframes/"
  },
  "dependencies": {
    "@tinycloud/share-envelope": "*",
    "@tinycloud/share-registry": "*",
    "dompurify": "3.4.12",
    "mermaid": "11.16.0",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@tinycloud/share-cli": "*",
    "@types/node": "^20.19.0",
    "jsdom": "^26.1.0",
    "puppeteer": "24.31.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
