FROM node:22.14.0-bookworm-slim@sha256:8b2a1f0e8d9d7c4d6b2a7f1f7d6b6a6d6c1e3c5c4e1b1e4c0a8d2c0e0b7e5a1f
WORKDIR /app
COPY package*.json ./
COPY packages ./packages
COPY src ./src
COPY public ./public
COPY index.html share.html viewer.html vite.config.* tsconfig.json ./
RUN npm ci --ignore-scripts && npm run build:deploy
USER node
ENV HOST=0.0.0.0 PORT=8787
EXPOSE 8787
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s CMD node -e "fetch('http://127.0.0.1:8787/health/readiness').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
CMD ["npm", "run", "start:deploy"]
